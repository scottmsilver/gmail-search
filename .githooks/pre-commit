#!/usr/bin/env bash
#
# FAST commit gate (seconds): ruff + a quick test smoke. The full test suite
# runs on pre-push and in CI — keeping commits fast so nobody reflexively
# --no-verify (which would defeat the gate).
#
# ruff catches the class that broke prod: undefined names from a formatter-
# stripped import (F821), unused imports (F401), redefinitions (F811).
#
# Enabled via:  git config core.hooksPath .githooks   (scripts/setup-dev.sh)
# Override:     git commit --no-verify        or   SKIP_HOOKS=1 git commit ...
set -uo pipefail
cd "$(git rev-parse --show-toplevel)" || exit 1

if [ "${SKIP_HOOKS:-}" = "1" ]; then
  echo "[pre-commit] SKIP_HOOKS=1 set — skipping ruff + smoke"
  exit 0
fi

RUFF="${GMS_RUFF:-ruff}"
PY="${GMS_PYTHON:-python}"
# Quick, high-signal subset (~7s). Override with GMS_PRECOMMIT_TESTS=".. .."
SMOKE="${GMS_PRECOMMIT_TESTS:-tests/test_agent_tools.py tests/test_sql_endpoint_security.py}"

echo "[pre-commit] ruff check (undefined names / unused imports / redefinitions)…"
if ! "$RUFF" check src/ tests/; then
  echo "[pre-commit] ✗ ruff failed — fix it (or bypass with: git commit --no-verify)" >&2
  exit 1
fi

echo "[pre-commit] pytest smoke ($SMOKE)…"
# shellcheck disable=SC2086
if ! "$PY" -m pytest -q $SMOKE; then
  echo "[pre-commit] ✗ smoke tests failed — fix them (or bypass with: git commit --no-verify)" >&2
  exit 1
fi

echo "[pre-commit] ✓ ruff + smoke passed (full suite runs on push / in CI)"
