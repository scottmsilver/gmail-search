[Unit]
Description=Gmail Search — continuous email sync and indexing
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=%h/anaconda3/bin/gmail-search watch --interval 300
WorkingDirectory=%h/development/gmail-search
EnvironmentFile=%h/.config/gmail-search/env
Restart=on-failure
RestartSec=30

[Install]
WantedBy=default.target
