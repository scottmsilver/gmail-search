.env
workspaces/

# Claude Code drops a lot of per-machine runtime state into
# claude-config/ — session logs, tool-result caches, OAuth tokens,
# growth-book feature flags, plans, shell snapshots, etc. None of it
# belongs in git, and the exact set of subdirectories changes between
# Claude Code versions. Default-deny + explicit allow keeps that drift
# from leaking into the repo.
claude-config/*
!claude-config/CLAUDE.md.template
!claude-config/settings.json
!claude-config/system-hint.txt
